# Harness Airgap Bundle Selection File
# ──────────────────────────────────────────────────────────────────────────────
# Use with: ./download-airgap-bundles.sh --version <ver> --output-dir ./bundles \
#               --selection-file selection.conf
#
# Tip: run --generate-selection-file to build this file interactively, or
#      run --list to see all available module, sub-bundle, and agent names.
# Lines starting with '#' are ignored.
# ──────────────────────────────────────────────────────────────────────────────

# Modules to download (comma-separated). Dependencies are auto-resolved.
# Example: cdng,ci,sto,platform
modules=

# Everything beyond the base modules — combined bundles (ci-plugins, sto-scanners)
# AND individual agent images (delegate, upgrader, argocd) — in a single key.
# Use 'all' to include everything, or 'none' to skip.
# Example: ci-plugins,sto-scanners,delegate,upgrader
sub-bundles=none
